# atlas.tcyr — kashi glyph atlas tests (M6 bite 8).
# Verifies the 128x256 RGBA8 atlas matches kashi_glyph_row bit-for-bit at the
# right cell offsets, plus geometry + cell-origin math. Stdlib auto-included.

include "lib/kashi_font_data.cyr"
include "src/render/atlas.cyr"

# 1 if atlas pixel (x,y) is opaque (glyph), 0 if transparent.
fn atlas_set(buf, x, y): i64 {
    if (load32(buf + (y * 128 + x) * 4) != 0) { return 1; }
    return 0;
}

# Count pixels in glyph cp's atlas cell that disagree with kashi's bitmap.
fn cell_mismatches(buf, cp): i64 {
    var cx = atlas_cell_x(cp);
    var cy = atlas_cell_y(cp);
    var mism = 0;
    var row = 0;
    while (row < 16) {
        var bits = kashi_glyph_row(0, cp, row);
        var col = 0;
        while (col < 8) {
            var want = 0;
            if ((bits & (1 << (7 - col))) != 0) { want = 1; }
            if (atlas_set(buf, cx + col, cy + row) != want) { mism = mism + 1; }
            col = col + 1;
        }
        row = row + 1;
    }
    return mism;
}

# Count opaque pixels in glyph cp's cell.
fn cell_opaque(buf, cp): i64 {
    var cx = atlas_cell_x(cp);
    var cy = atlas_cell_y(cp);
    var n = 0;
    var row = 0;
    while (row < 16) {
        var col = 0;
        while (col < 8) {
            n = n + atlas_set(buf, cx + col, cy + row);
            col = col + 1;
        }
        row = row + 1;
    }
    return n;
}

fn main(): i64 {
    alloc_init();
    kashi_font_init();

    test_group("atlas: geometry");
    assert_eq(atlas_w(), 128, "atlas width = 16*8");
    assert_eq(atlas_h(), 256, "atlas height = 16*16");
    assert_eq(atlas_bytes(), 131072, "atlas bytes = 128*256*4 (128 KiB)");
    assert_eq(atlas_cell_x(0x41), 8, "'A' (65) cell x = (65%16)*8 = 8");
    assert_eq(atlas_cell_y(0x41), 64, "'A' (65) cell y = (65/16)*16 = 64");
    assert_eq(atlas_cell_x(0), 0, "glyph 0 cell x = 0");
    assert_eq(atlas_cell_y(0), 0, "glyph 0 cell y = 0");

    var buf = alloc(atlas_bytes());
    atlas_build_kashi(buf, 0);

    test_group("atlas: matches kashi bit-for-bit");
    assert_eq(cell_mismatches(buf, 0x41), 0, "'A' cell matches kashi");
    assert_eq(cell_mismatches(buf, 0x20), 0, "space cell matches kashi");
    assert_eq(cell_mismatches(buf, 0x30), 0, "'0' cell matches kashi");
    assert_eq(cell_mismatches(buf, 0xDB), 0, "full-block (0xDB) cell matches kashi");

    test_group("atlas: coverage sanity");
    assert_eq(cell_opaque(buf, 0x20), 0, "space is fully transparent");
    assert_gt(cell_opaque(buf, 0x41), 0, "'A' has opaque pixels");
    assert_eq(cell_opaque(buf, 0xDB), 128, "full-block fills its whole 8x16 cell");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
