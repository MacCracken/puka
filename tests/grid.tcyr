# grid.tcyr — cell grid model tests (Bite 3 / M1).
# Stdlib auto-included via cyrius.cyml.

include "src/grid.cyr"

# Clear the dirty bit on every row 0..rows-1 (test setup helper).
fn clear_dirty(rows): i64 {
    var r = 0;
    while (r < rows) { grid_clear_row_dirty(r); r = r + 1; }
    return 0;
}

fn main() {
    alloc_init();

    test_group("init + dimensions");
    grid_init(24, 80);
    assert_eq(grid_get_rows(), 24, "24 rows");
    assert_eq(grid_get_cols(), 80, "80 cols");
    assert_eq(grid_cursor_row(), 0, "cursor row 0");
    assert_eq(grid_cursor_col(), 0, "cursor col 0");
    assert_eq(grid_scroll_top_get(), 0, "scroll top 0");
    assert_eq(grid_scroll_bot_get(), 23, "scroll bottom 23");
    assert_eq(grid_glyph(0, 0), 0x20, "fresh cell is blank space");

    test_group("dimension clamping");
    grid_init(9999, 9999);
    assert_eq(grid_get_rows(), GRID_MAX_ROWS, "rows clamped to max");
    assert_eq(grid_get_cols(), GRID_MAX_COLS, "cols clamped to max");

    test_group("set / get cell + pen");
    grid_init(24, 80);
    grid_set_pen(ATTR_BOLD | ATTR_UNDERLINE, 33, 44);
    grid_put_cell(2, 5, 0x41);   # 'A' with current pen
    assert_eq(grid_glyph(2, 5), 0x41, "glyph A stored");
    assert_eq(grid_attr(2, 5), ATTR_BOLD | ATTR_UNDERLINE, "attrs stored");
    assert_eq(grid_fg(2, 5), 33, "fg stored");
    assert_eq(grid_bg(2, 5), 44, "bg stored");
    grid_set_cell(2, 6, 0x10FFFF, 0, 0, 0);   # max codepoint round-trips
    assert_eq(grid_glyph(2, 6), 0x10FFFF, "max codepoint round-trips");

    test_group("out-of-bounds is safe");
    grid_set_cell(999, 999, 0x42, 0, 0, 0);   # no crash, no write
    assert_eq(grid_glyph(0, 0), 0x20, "oob write ignored");
    assert_eq(grid_glyph(999, 999), 0x20, "oob read returns blank");

    test_group("cursor clamping");
    grid_init(24, 80);
    grid_cursor_set(100, 200);
    assert_eq(grid_cursor_row(), 23, "row clamped to 23");
    assert_eq(grid_cursor_col(), 79, "col clamped to 79");
    grid_cursor_set(0 - 5, 0 - 5);
    assert_eq(grid_cursor_row(), 0, "negative row clamped to 0");
    assert_eq(grid_cursor_col(), 0, "negative col clamped to 0");

    test_group("erase cells (bce uses pen bg)");
    grid_init(24, 80);
    grid_set_pen(0, 0, 7);          # pen bg = 7
    grid_set_cell(1, 0, 0x58, ATTR_BOLD, 1, 2);   # 'X'
    grid_set_cell(1, 1, 0x59, ATTR_BOLD, 1, 2);   # 'Y'
    grid_erase_cells(1, 0, 1);
    assert_eq(grid_glyph(1, 0), 0x20, "erased to space");
    assert_eq(grid_attr(1, 0), 0, "erased attrs cleared");
    assert_eq(grid_bg(1, 0), 7, "erased cell takes pen bg (bce)");
    assert_eq(grid_fg(1, 0), 0, "erased fg default");

    test_group("scroll up");
    grid_init(4, 8);
    grid_put_cell(0, 0, 0x41);  # row0 'A'
    grid_put_cell(1, 0, 0x42);  # row1 'B'
    grid_put_cell(2, 0, 0x43);  # row2 'C'
    grid_put_cell(3, 0, 0x44);  # row3 'D'
    grid_scroll_up(1);
    assert_eq(grid_glyph(0, 0), 0x42, "row0 now B (was row1)");
    assert_eq(grid_glyph(1, 0), 0x43, "row1 now C");
    assert_eq(grid_glyph(2, 0), 0x44, "row2 now D");
    assert_eq(grid_glyph(3, 0), 0x20, "row3 blanked");

    test_group("scroll down");
    grid_init(4, 8);
    grid_put_cell(0, 0, 0x41);
    grid_put_cell(1, 0, 0x42);
    grid_put_cell(2, 0, 0x43);
    grid_put_cell(3, 0, 0x44);
    grid_scroll_down(1);
    assert_eq(grid_glyph(0, 0), 0x20, "row0 blanked");
    assert_eq(grid_glyph(1, 0), 0x41, "row1 now A (was row0)");
    assert_eq(grid_glyph(2, 0), 0x42, "row2 now B");
    assert_eq(grid_glyph(3, 0), 0x43, "row3 now C");

    test_group("scroll region confines scrolling");
    grid_init(5, 8);
    grid_put_cell(0, 0, 0x30);  # '0' outside region
    grid_put_cell(1, 0, 0x31);  # '1'
    grid_put_cell(2, 0, 0x32);  # '2'
    grid_put_cell(3, 0, 0x33);  # '3'
    grid_put_cell(4, 0, 0x34);  # '4' outside region
    grid_set_scroll(1, 3);      # region rows 1..3
    grid_scroll_up(1);
    assert_eq(grid_glyph(0, 0), 0x30, "row0 untouched (outside region)");
    assert_eq(grid_glyph(1, 0), 0x32, "row1 now '2'");
    assert_eq(grid_glyph(2, 0), 0x33, "row2 now '3'");
    assert_eq(grid_glyph(3, 0), 0x20, "row3 blanked (region bottom)");
    assert_eq(grid_glyph(4, 0), 0x34, "row4 untouched (outside region)");

    test_group("tab stops");
    grid_init(24, 80);
    assert_eq(grid_next_tab(0), 8, "first tab at col 8");
    assert_eq(grid_next_tab(8), 16, "next tab at 16");
    assert_eq(grid_next_tab(75), 79, "past last tabstop clamps to last col");
    grid_tab_clear(16);
    assert_eq(grid_next_tab(8), 24, "cleared tab at 16 -> next is 24");
    grid_tab_set(10);
    assert_eq(grid_next_tab(8), 10, "custom tab at 10");
    grid_tab_clear_all();
    assert_eq(grid_next_tab(0), 79, "no tabs -> clamp to last col");

    test_group("resize");
    grid_init(24, 80);
    grid_put_cell(0, 0, 0x41);          # 'A' survives a shrink it's inside
    grid_cursor_set(20, 70);
    grid_resize(10, 40);
    assert_eq(grid_get_rows(), 10, "resized to 10 rows");
    assert_eq(grid_get_cols(), 40, "resized to 40 cols");
    assert_eq(grid_glyph(0, 0), 0x41, "in-bounds content preserved");
    assert_eq(grid_cursor_row(), 9, "cursor clamped to new last row");
    assert_eq(grid_cursor_col(), 39, "cursor clamped to new last col");
    assert_eq(grid_scroll_bot_get(), 9, "scroll region reset to full height");
    grid_resize(99, 99);
    assert_eq(grid_get_rows(), 99, "grow to 99 rows (within the raised ceiling)");
    assert_eq(grid_get_cols(), 99, "grow to 99 cols");
    assert_eq(grid_glyph(5, 50), 0x20, "newly-exposed cell is blank");
    grid_resize(9999, 9999);
    assert_eq(grid_get_rows(), GRID_MAX_ROWS, "grow clamps to max rows");
    assert_eq(grid_get_cols(), GRID_MAX_COLS, "grow clamps to max cols");

    test_group("damage: per-row dirty tracking");
    grid_init(10, 20);
    assert_eq(grid_row_dirty(0), 1, "init marks row 0 dirty");
    assert_eq(grid_row_dirty(9), 1, "init marks last row dirty");
    clear_dirty(10);
    assert_eq(grid_row_dirty(0), 0, "cleared row 0 is clean");
    assert_eq(grid_row_dirty(5), 0, "cleared row 5 is clean");
    grid_put_cell(3, 2, 0x41);                  # write one cell
    assert_eq(grid_row_dirty(3), 1, "cell write marks its row");
    assert_eq(grid_row_dirty(2), 0, "neighbour row 2 stays clean");
    assert_eq(grid_row_dirty(4), 0, "neighbour row 4 stays clean");
    clear_dirty(10);
    grid_cursor_set(0, 0);                       # known start row
    clear_dirty(10);
    grid_cursor_set(6, 4);                        # move row 0 -> row 6
    assert_eq(grid_row_dirty(0), 1, "cursor move marks the old row");
    assert_eq(grid_row_dirty(6), 1, "cursor move marks the new row");
    assert_eq(grid_row_dirty(3), 0, "an untouched row stays clean");
    clear_dirty(10);
    grid_scroll_up(1);                            # rewrites every region row
    assert_eq(grid_row_dirty(0), 1, "scroll marks row 0");
    assert_eq(grid_row_dirty(9), 1, "scroll marks the last row");
    assert_eq(grid_row_dirty(0 - 1), 0, "negative row dirty query -> 0");
    assert_eq(grid_row_dirty(9999), 0, "out-of-range row dirty query -> 0");

    test_group("damage: multi-word bitset (rows >= 64)");
    grid_init(100, 20);                          # spans dirty word 0 (0..63) and 1 (64..99)
    clear_dirty(100);
    grid_put_cell(70, 2, 0x41);                  # write a row in the 2nd word
    assert_eq(grid_row_dirty(70), 1, "row 70 (word 1) marks dirty");
    assert_eq(grid_row_dirty(6), 0, "row 6 (word 0) stays clean across the word boundary");
    assert_eq(grid_row_dirty(69), 0, "row 69 stays clean");
    assert_eq(grid_row_dirty(71), 0, "row 71 stays clean");
    grid_put_cell(63, 0, 0x42);                  # last bit of word 0
    grid_put_cell(64, 0, 0x43);                  # first bit of word 1
    assert_eq(grid_row_dirty(63), 1, "row 63 (word 0 MSB) marks dirty");
    assert_eq(grid_row_dirty(64), 1, "row 64 (word 1 LSB) marks dirty");
    grid_clear_row_dirty(70);
    assert_eq(grid_row_dirty(70), 0, "cleared row 70 is clean");
    assert_eq(grid_row_dirty(63), 1, "clearing row 70 left row 63 dirty");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
