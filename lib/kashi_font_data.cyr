# === kashi — freestanding console-font data core ===
#
# THIS FILE IS FREESTANDING. It uses NO stdlib, NO sakshi, NO heap, NO
# syscalls — only the `store8` / `load8` pointer intrinsics and integer
# arithmetic. A freestanding kernel (agnos: `[deps] stdlib = []`, vendored
# klib/) can `include` this file directly and get bitmap glyph data without
# linking the Cyrius stdlib. Do NOT add stdlib includes here — that breaks
# the load-bearing consumption contract (see docs/adr/0001).
#
# The full kashi library face (PSF1/PSF2 import, runtime font loading) is a
# SEPARATE, stdlib-using surface (src/lib.cyr) and never reaches this file.
#
# --- Fonts carried ---
#
# Font 0 — IBM VGA BIOS 8x16 ROM font (public domain, IBM 1981; the same
#   byte table Linux's lib/fonts/font_8x16.c carries). 96 glyphs covering
#   printable ASCII 0x20..0x7F. Each glyph is 16 rows top-to-bottom; bit 7
#   = leftmost pixel of that row. Legible at 2K+ native HDMI (cell 8x16 is
#   ~1.5% of screen height at 1080p). This is the table agnos's
#   kernel/arch/x86_64/fb_console.cyr currently uses.
#
# Font 1 — hand-drawn 8x8 CGA-style bitmap (public domain, AGNOS original).
#   96 glyphs, ASCII 0x20..0x7F, 8 rows per glyph. Smaller; the original
#   agnos console font before the 8x16 replacement. Retained here so the
#   8x8 source survives the kernel-side migration and stays available for
#   low-resolution / dense-grid uses (BBS-style art, tiny status lines).
#
# --- Storage model ---
#
# Two module-scope BSS buffers, BYTE-addressed via store8/load8. NOTE the
# Cyrius var-array unit rule: at MODULE scope `var X[N]` allocates N*u64
# (8N bytes), so `var kashi_font16[3584]` reserves 28 KiB of BSS but we use
# only the first 3584 BYTES (one byte per glyph row). `var kashi_font8[1792]`
# reserves 14 KiB and uses the first 1792 bytes. See architecture note 001
# for the rationale of using bytes as the var-array N. As of 0.4.0 the
# range covers all of CP437 (224 glyphs); agnos's `fb_font` will widen to
# match when it integrates kashi.
#
# Glyph rows are packed top-to-bottom by `kashi_font_init()` from u64 literals
# that read in scan order: for the 8x16 font, fset16(ch, hi, lo) where
# hi = rows 0-7 (top), lo = rows 8-15; for the 8x8 font, fset8(ch, val)
# where val = rows 0-7. byte (literal >> 56) is the topmost row.
#
# --- Consumption contract (agnos kernel, integrated at agnos 1.38.0) ---
#
#   [deps.kashi]
#   path    = "../kashi"
#   modules = ["src/font_data.cyr"]
#
# Then, once at boot (before the first glyph render):
#   kashi_font_init();
# Per-glyph render:
#   var p = kashi_glyph_ptr(KASHI_FONT_VGA_8X16, ch);   # base of 16 row bytes
#   var bits = kashi_glyph_row(KASHI_FONT_VGA_8X16, ch, row);  # one row byte
# Metadata:
#   kashi_font_width(id) / kashi_font_height(id) / kashi_font_first(id) /
#   kashi_font_count(id) / kashi_font_stride(id)

# --- Font identifiers (enum-style constants; pass to every accessor) ---
# Enum values are compile-time constants — they do NOT consume gvar slots,
# unlike module-scope `var X = ...`. Named + semicolon-separated per the
# Cyrius grammar.
enum KashiFontId {
    KASHI_FONT_VGA_8X16 = 0;   # IBM VGA BIOS 8x16
    KASHI_FONT_CGA_8X8 = 1;    # hand-drawn 8x8 CGA-style
    KASHI_FONT_VGA_9X16 = 2;   # VGA 9x16 (derived from font16 + VGA col-9 rule; ADR 0006)
}

# All three built-in fonts cover the full CP437 range (0x20..0xFF, 224
# glyphs). VGA 8x16 carries the IBM VGA BIOS bytes (sourced from Linux's
# public-domain font_8x16.c; ADR 0004). CGA 8x8 is dual-sourced:
# hand-drawn AGNOS-original ASCII low half (0x20..0x7F) + Linux PD
# font_8x8.c high half (ADR 0007). VGA 9x16 is derived from VGA 8x16 +
# the VGA col-9 replication rule at init (ADR 0006); no separate byte
# table on disk.
enum KashiGlyphRange {
    KASHI_GLYPH_FIRST = 0x20;  # first encoded codepoint (space)
    KASHI_GLYPH_LAST = 0xFF;   # last encoded codepoint (last CP437 cell)
    KASHI_GLYPH_COUNT = 224;   # 0xFF - 0x20 + 1
}

# Module-scope BSS. See the "Storage model" note above for the u64-unit
# rule: these reserve 8x their byte footprint but we address them per-byte.
var kashi_font16[3584];    # 224 glyphs x 16 rows (VGA 8x16)        — bytes 0..3583
var kashi_font8[1792];     # 224 glyphs x  8 rows (CGA 8x8)         — bytes 0..1791
var kashi_font9_16[7168];  # 224 glyphs x 16 rows x 2 bytes (VGA 9x16, derived)
var kashi_font_ready = 0;  # 1 after kashi_font_init() has run

# Pack one 8x16 glyph's 16 row-bytes into kashi_font16[(ch-0x20)*16 .. +15].
# hi = rows 0-7 (top first), lo = rows 8-15. Byte (hi>>56) is the top row.
# Internal — callers use kashi_font_init(). ch is trusted (table-internal).
fn kashi_fset16(ch, hi, lo) {
    # Defensive bound (audit 2026-05-27, F1): a table-authoring typo with
    # ch outside [FIRST, LAST] would compute a negative or overrun offset
    # and silently corrupt BSS before/after the buffer. init runs once, so
    # this guard is free. All current calls are in-range; this protects
    # any future built-in font added past the current three.
    if (ch < KASHI_GLYPH_FIRST) { return 0; }
    if (ch > KASHI_GLYPH_LAST) { return 0; }
    var g = &kashi_font16 + (ch - KASHI_GLYPH_FIRST) * 16;
    store8(g + 0, (hi >> 56) & 0xFF);
    store8(g + 1, (hi >> 48) & 0xFF);
    store8(g + 2, (hi >> 40) & 0xFF);
    store8(g + 3, (hi >> 32) & 0xFF);
    store8(g + 4, (hi >> 24) & 0xFF);
    store8(g + 5, (hi >> 16) & 0xFF);
    store8(g + 6, (hi >> 8) & 0xFF);
    store8(g + 7, hi & 0xFF);
    store8(g + 8, (lo >> 56) & 0xFF);
    store8(g + 9, (lo >> 48) & 0xFF);
    store8(g + 10, (lo >> 40) & 0xFF);
    store8(g + 11, (lo >> 32) & 0xFF);
    store8(g + 12, (lo >> 24) & 0xFF);
    store8(g + 13, (lo >> 16) & 0xFF);
    store8(g + 14, (lo >> 8) & 0xFF);
    store8(g + 15, lo & 0xFF);
    return 0;
}

# Pack one 8x8 glyph's 8 row-bytes into kashi_font8[(ch-0x20)*8 .. +7].
# val = rows 0-7, byte (val>>56) is the top row. Internal.
fn kashi_fset8(ch, val) {
    # Defensive bound — see kashi_fset16 (audit 2026-05-27, F1).
    if (ch < KASHI_GLYPH_FIRST) { return 0; }
    if (ch > KASHI_GLYPH_LAST) { return 0; }
    var g = &kashi_font8 + (ch - KASHI_GLYPH_FIRST) * 8;
    store8(g + 0, (val >> 56) & 0xFF);
    store8(g + 1, (val >> 48) & 0xFF);
    store8(g + 2, (val >> 40) & 0xFF);
    store8(g + 3, (val >> 32) & 0xFF);
    store8(g + 4, (val >> 24) & 0xFF);
    store8(g + 5, (val >> 16) & 0xFF);
    store8(g + 6, (val >> 8) & 0xFF);
    store8(g + 7, val & 0xFF);
    return 0;
}

# Populate both glyph buffers. Idempotent — safe to call more than once.
# Call ONCE before the first glyph access (a freestanding consumer has no
# constructor mechanism, so this is explicit). Returns 0.
fn kashi_font_init() {
    # --- Font 0: IBM VGA BIOS 8x16 ROM font (public domain). ---
    # Byte-for-byte the table agnos's fb_console.cyr carries; hi = rows 0-7,
    # lo = rows 8-15. Each literal reads top-to-bottom as
    # 0xR0R1R2R3R4R5R6R7 0xR8R9RARBRCRDRERF.
    kashi_fset16(0x20, 0x0000000000000000, 0x0000000000000000);  # space
    kashi_fset16(0x21, 0x0000183C3C3C1818, 0x1800181800000000);  # !
    kashi_fset16(0x22, 0x0066666624000000, 0x0000000000000000);  # "
    kashi_fset16(0x23, 0x0000006C6CFE6C6C, 0x6CFE6C6C00000000);  # #
    kashi_fset16(0x24, 0x18187CC6C2C07C06, 0x0686C67C18180000);  # $
    kashi_fset16(0x25, 0x00000000C2C60C18, 0x3060C68600000000);  # %
    kashi_fset16(0x26, 0x0000386C6C3876DC, 0xCCCCCC7600000000);  # &
    kashi_fset16(0x27, 0x0030303060000000, 0x0000000000000000);  # '
    kashi_fset16(0x28, 0x00000C1830303030, 0x3030180C00000000);  # (
    kashi_fset16(0x29, 0x000030180C0C0C0C, 0x0C0C183000000000);  # )
    kashi_fset16(0x2A, 0x0000000000663CFF, 0x3C66000000000000);  # *
    kashi_fset16(0x2B, 0x000000000018187E, 0x1818000000000000);  # +
    kashi_fset16(0x2C, 0x0000000000000000, 0x0018181830000000);  # ,
    kashi_fset16(0x2D, 0x00000000000000FE, 0x0000000000000000);  # -
    kashi_fset16(0x2E, 0x0000000000000000, 0x0000181800000000);  # .
    kashi_fset16(0x2F, 0x0000000002060C18, 0x3060C08000000000);  # /
    kashi_fset16(0x30, 0x0000386CC6C6D6D6, 0xC6C66C3800000000);  # 0
    kashi_fset16(0x31, 0x0000183878181818, 0x1818187E00000000);  # 1
    kashi_fset16(0x32, 0x00007CC6060C1830, 0x60C0C6FE00000000);  # 2
    kashi_fset16(0x33, 0x00007CC606063C06, 0x0606C67C00000000);  # 3
    kashi_fset16(0x34, 0x00000C1C3C6CCCFE, 0x0C0C0C1E00000000);  # 4
    kashi_fset16(0x35, 0x0000FEC0C0C0FC06, 0x0606C67C00000000);  # 5
    kashi_fset16(0x36, 0x00003860C0C0FCC6, 0xC6C6C67C00000000);  # 6
    kashi_fset16(0x37, 0x0000FEC606060C18, 0x3030303000000000);  # 7
    kashi_fset16(0x38, 0x00007CC6C6C67CC6, 0xC6C6C67C00000000);  # 8
    kashi_fset16(0x39, 0x00007CC6C6C67E06, 0x06060C7800000000);  # 9
    kashi_fset16(0x3A, 0x0000000018180000, 0x0018180000000000);  # :
    kashi_fset16(0x3B, 0x0000000018180000, 0x0018183000000000);  # ;
    kashi_fset16(0x3C, 0x000000060C183060, 0x30180C0600000000);  # <
    kashi_fset16(0x3D, 0x00000000007E0000, 0x7E00000000000000);  # =
    kashi_fset16(0x3E, 0x0000006030180C06, 0x0C18306000000000);  # >
    kashi_fset16(0x3F, 0x00007CC6C60C1818, 0x1800181800000000);  # ?
    kashi_fset16(0x40, 0x0000007CC6C6DEDE, 0xDEDCC07C00000000);  # @
    kashi_fset16(0x41, 0x000010386CC6C6FE, 0xC6C6C6C600000000);  # A
    kashi_fset16(0x42, 0x0000FC6666667C66, 0x666666FC00000000);  # B
    kashi_fset16(0x43, 0x00003C66C2C0C0C0, 0xC0C2663C00000000);  # C
    kashi_fset16(0x44, 0x0000F86C66666666, 0x66666CF800000000);  # D
    kashi_fset16(0x45, 0x0000FE6662687868, 0x606266FE00000000);  # E
    kashi_fset16(0x46, 0x0000FE6662687868, 0x606060F000000000);  # F
    kashi_fset16(0x47, 0x00003C66C2C0C0DE, 0xC6C6663A00000000);  # G
    kashi_fset16(0x48, 0x0000C6C6C6C6FEC6, 0xC6C6C6C600000000);  # H
    kashi_fset16(0x49, 0x00003C1818181818, 0x1818183C00000000);  # I
    kashi_fset16(0x4A, 0x00001E0C0C0C0C0C, 0xCCCCCC7800000000);  # J
    kashi_fset16(0x4B, 0x0000E666666C7878, 0x6C6666E600000000);  # K
    kashi_fset16(0x4C, 0x0000F06060606060, 0x606266FE00000000);  # L
    kashi_fset16(0x4D, 0x0000C6EEFEFED6C6, 0xC6C6C6C600000000);  # M
    kashi_fset16(0x4E, 0x0000C6E6F6FEDECE, 0xC6C6C6C600000000);  # N
    kashi_fset16(0x4F, 0x00007CC6C6C6C6C6, 0xC6C6C67C00000000);  # O
    kashi_fset16(0x50, 0x0000FC6666667C60, 0x606060F000000000);  # P
    kashi_fset16(0x51, 0x00007CC6C6C6C6C6, 0xC6D6DE7C0C0E0000);  # Q
    kashi_fset16(0x52, 0x0000FC6666667C6C, 0x666666E600000000);  # R
    kashi_fset16(0x53, 0x00007CC6C660380C, 0x06C6C67C00000000);  # S
    kashi_fset16(0x54, 0x00007E7E5A181818, 0x1818183C00000000);  # T
    kashi_fset16(0x55, 0x0000C6C6C6C6C6C6, 0xC6C6C67C00000000);  # U
    kashi_fset16(0x56, 0x0000C6C6C6C6C6C6, 0xC66C381000000000);  # V
    kashi_fset16(0x57, 0x0000C6C6C6C6D6D6, 0xD6FEEE6C00000000);  # W
    kashi_fset16(0x58, 0x0000C6C66C7C3838, 0x7C6CC6C600000000);  # X
    kashi_fset16(0x59, 0x0000666666663C18, 0x1818183C00000000);  # Y
    kashi_fset16(0x5A, 0x0000FEC6860C1830, 0x60C2C6FE00000000);  # Z
    kashi_fset16(0x5B, 0x00003C3030303030, 0x3030303C00000000);  # [
    kashi_fset16(0x5C, 0x00000080C0E07038, 0x1C0E060200000000);  # backslash
    kashi_fset16(0x5D, 0x00003C0C0C0C0C0C, 0x0C0C0C3C00000000);  # ]
    kashi_fset16(0x5E, 0x10386CC600000000, 0x0000000000000000);  # ^
    kashi_fset16(0x5F, 0x0000000000000000, 0x0000000000FF0000);  # _
    kashi_fset16(0x60, 0x0030180C00000000, 0x0000000000000000);  # `
    kashi_fset16(0x61, 0x0000000000780C7C, 0xCCCCCC7600000000);  # a
    kashi_fset16(0x62, 0x0000E06060786C66, 0x6666667C00000000);  # b
    kashi_fset16(0x63, 0x00000000007CC6C0, 0xC0C0C67C00000000);  # c
    kashi_fset16(0x64, 0x00001C0C0C3C6CCC, 0xCCCCCC7600000000);  # d
    kashi_fset16(0x65, 0x00000000007CC6FE, 0xC0C0C67C00000000);  # e
    kashi_fset16(0x66, 0x00001C3632307830, 0x3030307800000000);  # f
    kashi_fset16(0x67, 0x000000000076CCCC, 0xCCCCCC7C0CCC7800);  # g
    kashi_fset16(0x68, 0x0000E060606C7666, 0x666666E600000000);  # h
    kashi_fset16(0x69, 0x0000181800381818, 0x1818183C00000000);  # i
    kashi_fset16(0x6A, 0x00000606000E0606, 0x0606060666663C00);  # j
    kashi_fset16(0x6B, 0x0000E06060666C78, 0x786C66E600000000);  # k
    kashi_fset16(0x6C, 0x0000381818181818, 0x1818183C00000000);  # l
    kashi_fset16(0x6D, 0x0000000000ECFED6, 0xD6D6D6C600000000);  # m
    kashi_fset16(0x6E, 0x0000000000DC6666, 0x6666666600000000);  # n
    kashi_fset16(0x6F, 0x00000000007CC6C6, 0xC6C6C67C00000000);  # o
    kashi_fset16(0x70, 0x0000000000DC6666, 0x6666667C6060F000);  # p
    kashi_fset16(0x71, 0x000000000076CCCC, 0xCCCCCC7C0C0C1E00);  # q
    kashi_fset16(0x72, 0x0000000000DC7666, 0x606060F000000000);  # r
    kashi_fset16(0x73, 0x00000000007CC660, 0x380CC67C00000000);  # s
    kashi_fset16(0x74, 0x0000103030FC3030, 0x3030361C00000000);  # t
    kashi_fset16(0x75, 0x0000000000CCCCCC, 0xCCCCCC7600000000);  # u
    kashi_fset16(0x76, 0x0000000000C6C6C6, 0xC6C66C3800000000);  # v
    kashi_fset16(0x77, 0x0000000000C6C6D6, 0xD6D6FE6C00000000);  # w
    kashi_fset16(0x78, 0x0000000000C66C38, 0x38386CC600000000);  # x
    kashi_fset16(0x79, 0x0000000000C6C6C6, 0xC6C6C67E060CF800);  # y
    kashi_fset16(0x7A, 0x0000000000FECC18, 0x3060C6FE00000000);  # z
    kashi_fset16(0x7B, 0x00000E1818187018, 0x1818180E00000000);  # {
    kashi_fset16(0x7C, 0x0000181818181818, 0x1818181800000000);  # |
    kashi_fset16(0x7D, 0x0000701818180E18, 0x1818187000000000);  # }
    kashi_fset16(0x7E, 0x0076DC0000000000, 0x0000000000000000);  # ~
    kashi_fset16(0x7F, 0x0000000010386CC6, 0xC6C6FE0000000000);  # DEL: CP437 triangle, not blank (matches IBM VGA)

    # --- VGA 8x16 high half (CP437 0x80..0xFF) — added in 0.4.0 (ADR 0004) ---
    # 128 glyphs sourced byte-for-byte from Linux's lib/fonts/font_8x16.c (the
    # same PD IBM VGA BIOS table whose ASCII half lives above). Mechanically
    # generated; fidelity spot-checked in tests/test.cyr.
    kashi_fset16(0x80, 0x00003C66C2C0C0C0, 0xC0C2663C18700000);  # CP437 0x80
    kashi_fset16(0x81, 0x0000CC0000CCCCCC, 0xCCCCCC7600000000);  # CP437 0x81
    kashi_fset16(0x82, 0x000C1830007CC6FE, 0xC0C0C67C00000000);  # CP437 0x82
    kashi_fset16(0x83, 0x0010386C00780C7C, 0xCCCCCC7600000000);  # CP437 0x83
    kashi_fset16(0x84, 0x0000CC0000780C7C, 0xCCCCCC7600000000);  # CP437 0x84
    kashi_fset16(0x85, 0x0060301800780C7C, 0xCCCCCC7600000000);  # CP437 0x85
    kashi_fset16(0x86, 0x00386C3800780C7C, 0xCCCCCC7600000000);  # CP437 0x86
    kashi_fset16(0x87, 0x00000000007CC6C0, 0xC0C0C67C18700000);  # CP437 0x87
    kashi_fset16(0x88, 0x0010386C007CC6FE, 0xC0C0C67C00000000);  # CP437 0x88
    kashi_fset16(0x89, 0x0000C600007CC6FE, 0xC0C0C67C00000000);  # CP437 0x89
    kashi_fset16(0x8A, 0x00603018007CC6FE, 0xC0C0C67C00000000);  # CP437 0x8A
    kashi_fset16(0x8B, 0x0000660000381818, 0x1818183C00000000);  # CP437 0x8B
    kashi_fset16(0x8C, 0x00183C6600381818, 0x1818183C00000000);  # CP437 0x8C
    kashi_fset16(0x8D, 0x0060301800381818, 0x1818183C00000000);  # CP437 0x8D
    kashi_fset16(0x8E, 0x00C60010386CC6C6, 0xFEC6C6C600000000);  # CP437 0x8E
    kashi_fset16(0x8F, 0x386C3810386CC6FE, 0xC6C6C6C600000000);  # CP437 0x8F
    kashi_fset16(0x90, 0x0C1800FE66626878, 0x686266FE00000000);  # CP437 0x90
    kashi_fset16(0x91, 0x0000000000EC3636, 0x7ED8D86E00000000);  # CP437 0x91
    kashi_fset16(0x92, 0x00003E6CCCCCFECC, 0xCCCCCCCE00000000);  # CP437 0x92
    kashi_fset16(0x93, 0x0010386C007CC6C6, 0xC6C6C67C00000000);  # CP437 0x93
    kashi_fset16(0x94, 0x0000C600007CC6C6, 0xC6C6C67C00000000);  # CP437 0x94
    kashi_fset16(0x95, 0x00603018007CC6C6, 0xC6C6C67C00000000);  # CP437 0x95
    kashi_fset16(0x96, 0x003078CC00CCCCCC, 0xCCCCCC7600000000);  # CP437 0x96
    kashi_fset16(0x97, 0x0060301800CCCCCC, 0xCCCCCC7600000000);  # CP437 0x97
    kashi_fset16(0x98, 0x0000C60000C6C6C6, 0xC6C6C67E060C7800);  # CP437 0x98
    kashi_fset16(0x99, 0x00C6007CC6C6C6C6, 0xC6C6C67C00000000);  # CP437 0x99
    kashi_fset16(0x9A, 0x00C600C6C6C6C6C6, 0xC6C6C67C00000000);  # CP437 0x9A
    kashi_fset16(0x9B, 0x0018187CC6C0C0C0, 0xC67C181800000000);  # CP437 0x9B
    kashi_fset16(0x9C, 0x00386C6460F06060, 0x6060E6FC00000000);  # CP437 0x9C
    kashi_fset16(0x9D, 0x000066663C187E18, 0x7E18181800000000);  # CP437 0x9D
    kashi_fset16(0x9E, 0x00F8CCCCF8C4CCDE, 0xCCCCCCC600000000);  # CP437 0x9E
    kashi_fset16(0x9F, 0x000E1B1818187E18, 0x1818D87000000000);  # CP437 0x9F
    kashi_fset16(0xA0, 0x0018306000780C7C, 0xCCCCCC7600000000);  # CP437 0xA0
    kashi_fset16(0xA1, 0x000C183000381818, 0x1818183C00000000);  # CP437 0xA1
    kashi_fset16(0xA2, 0x00183060007CC6C6, 0xC6C6C67C00000000);  # CP437 0xA2
    kashi_fset16(0xA3, 0x0018306000CCCCCC, 0xCCCCCC7600000000);  # CP437 0xA3
    kashi_fset16(0xA4, 0x000076DC00DC6666, 0x6666666600000000);  # CP437 0xA4
    kashi_fset16(0xA5, 0x76DC00C6E6F6FEDE, 0xCEC6C6C600000000);  # CP437 0xA5
    kashi_fset16(0xA6, 0x00003C6C6C3E007E, 0x0000000000000000);  # CP437 0xA6
    kashi_fset16(0xA7, 0x0000386C6C38007C, 0x0000000000000000);  # CP437 0xA7
    kashi_fset16(0xA8, 0x0000303000303060, 0xC0C6C67C00000000);  # CP437 0xA8
    kashi_fset16(0xA9, 0x000000000000FEC0, 0xC0C0C00000000000);  # CP437 0xA9
    kashi_fset16(0xAA, 0x000000000000FE06, 0x0606060000000000);  # CP437 0xAA
