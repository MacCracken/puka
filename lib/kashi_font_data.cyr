    kashi_fset8(0xB6, 0x6C6C6C6C6CEC6C6C);  # CP437 0xB6
    kashi_fset8(0xB7, 0x000000FC6C6C6C6C);  # CP437 0xB7
    kashi_fset8(0xB8, 0x0000F818F8181818);  # CP437 0xB8
    kashi_fset8(0xB9, 0x6CEC0CEC6C6C6C6C);  # CP437 0xB9
    kashi_fset8(0xBA, 0x6C6C6C6C6C6C6C6C);  # CP437 0xBA
    kashi_fset8(0xBB, 0x0000FC0CEC6C6C6C);  # CP437 0xBB
    kashi_fset8(0xBC, 0x6C6C0CFC00000000);  # CP437 0xBC
    kashi_fset8(0xBD, 0x6C6C6CFC00000000);  # CP437 0xBD
    kashi_fset8(0xBE, 0x1818F818F8000000);  # CP437 0xBE
    kashi_fset8(0xBF, 0x000000F818181818);  # CP437 0xBF
    kashi_fset8(0xC0, 0x181818181F000000);  # CP437 0xC0
    kashi_fset8(0xC1, 0x18181818FF000000);  # CP437 0xC1
    kashi_fset8(0xC2, 0x000000FF18181818);  # CP437 0xC2
    kashi_fset8(0xC3, 0x181818181F181818);  # CP437 0xC3
    kashi_fset8(0xC4, 0x000000FF00000000);  # CP437 0xC4
    kashi_fset8(0xC5, 0x18181818FF181818);  # CP437 0xC5
    kashi_fset8(0xC6, 0x181F181F18181818);  # CP437 0xC6
    kashi_fset8(0xC7, 0x6C6C6C6C6F6C6C6C);  # CP437 0xC7
    kashi_fset8(0xC8, 0x6C6C6F606F000000);  # CP437 0xC8
    kashi_fset8(0xC9, 0x00003F3037363636);  # CP437 0xC9 — double upper-left corner
    kashi_fset8(0xCA, 0x6C6CEF00EF000000);  # CP437 0xCA
    kashi_fset8(0xCB, 0x0000FF00EF6C6C6C);  # CP437 0xCB
    kashi_fset8(0xCC, 0x6C6C6F606F6C6C6C);  # CP437 0xCC
    kashi_fset8(0xCD, 0x0000FF00FF000000);  # CP437 0xCD — double horizontal
    kashi_fset8(0xCE, 0x6C6CEF00EF6C6C6C);  # CP437 0xCE
    kashi_fset8(0xCF, 0x1818FF00FF000000);  # CP437 0xCF
    kashi_fset8(0xD0, 0x6C6C6C6CFF000000);  # CP437 0xD0
    kashi_fset8(0xD1, 0x0000FF00FF181818);  # CP437 0xD1
    kashi_fset8(0xD2, 0x000000FF6C6C6C6C);  # CP437 0xD2
    kashi_fset8(0xD3, 0x6C6C6C6C7C000000);  # CP437 0xD3
    kashi_fset8(0xD4, 0x18181F181F000000);  # CP437 0xD4
    kashi_fset8(0xD5, 0x0000001F18181818);  # CP437 0xD5
    kashi_fset8(0xD6, 0x0000007C6C6C6C6C);  # CP437 0xD6
    kashi_fset8(0xD7, 0x6C6C6C6CFF6C6C6C);  # CP437 0xD7
    kashi_fset8(0xD8, 0x1818FF18FF181818);  # CP437 0xD8
    kashi_fset8(0xD9, 0x18181818F8000000);  # CP437 0xD9
    kashi_fset8(0xDA, 0x000000001F181818);  # CP437 0xDA
    kashi_fset8(0xDB, 0xFFFFFFFFFFFFFFFF);  # CP437 0xDB — full block
    kashi_fset8(0xDC, 0x00000000FFFFFFFF);  # CP437 0xDC — lower half
    kashi_fset8(0xDD, 0xF0F0F0F0F0F0F0F0);  # CP437 0xDD — left half
    kashi_fset8(0xDE, 0x0F0F0F0F0F0F0F0F);  # CP437 0xDE — right half
    kashi_fset8(0xDF, 0xFFFFFFFF00000000);  # CP437 0xDF — upper half
    kashi_fset8(0xE0, 0x000076DCC8DC7600);  # CP437 0xE0
    kashi_fset8(0xE1, 0x0078CCF8CCF8C0C0);  # CP437 0xE1
    kashi_fset8(0xE2, 0x00FEC6C0C0C0C000);  # CP437 0xE2
    kashi_fset8(0xE3, 0x00FE6C6C6C6C6C00);  # CP437 0xE3
    kashi_fset8(0xE4, 0xFEC6603060C6FE00);  # CP437 0xE4
    kashi_fset8(0xE5, 0x000000007ED8D870);  # CP437 0xE5
    kashi_fset8(0xE6, 0x00006666667C60C0);  # CP437 0xE6
    kashi_fset8(0xE7, 0x000076DC18181800);  # CP437 0xE7
    kashi_fset8(0xE8, 0x7E183C6666663C18);  # CP437 0xE8
    kashi_fset8(0xE9, 0x386CC6FEC6C66C38);  # CP437 0xE9
    kashi_fset8(0xEA, 0x386CC6C66C6C6CEE);  # CP437 0xEA
    kashi_fset8(0xEB, 0x1E30187CCCCCCC78);  # CP437 0xEB
    kashi_fset8(0xEC, 0x0000007EDBDB7E00);  # CP437 0xEC
    kashi_fset8(0xED, 0x06067EDBDB7EC0C0);  # CP437 0xED
    kashi_fset8(0xEE, 0x386060607C606038);  # CP437 0xEE
    kashi_fset8(0xEF, 0x7CC6C6C6C6C6C600);  # CP437 0xEF
    kashi_fset8(0xF0, 0x00FE0000FE0000FE);  # CP437 0xF0
    kashi_fset8(0xF1, 0x18187E18187E0000);  # CP437 0xF1
    kashi_fset8(0xF2, 0x60301818306000FC);  # CP437 0xF2
    kashi_fset8(0xF3, 0x180C0C18306000FC);  # CP437 0xF3
    kashi_fset8(0xF4, 0x0E1B1B1818181818);  # CP437 0xF4
    kashi_fset8(0xF5, 0x18181818D8D8D870);  # CP437 0xF5
    kashi_fset8(0xF6, 0x18180018187E0000);  # CP437 0xF6
    kashi_fset8(0xF7, 0x0076DC0076DC0000);  # CP437 0xF7
    kashi_fset8(0xF8, 0x386C6C3800000000);  # CP437 0xF8
    kashi_fset8(0xF9, 0x0000001818000000);  # CP437 0xF9
    kashi_fset8(0xFA, 0x0000001800000000);  # CP437 0xFA
    kashi_fset8(0xFB, 0x0F0C0C0CEC6C3C1C);  # CP437 0xFB
    kashi_fset8(0xFC, 0x6C36363636000000);  # CP437 0xFC
    kashi_fset8(0xFD, 0x780C18307C000000);  # CP437 0xFD
    kashi_fset8(0xFE, 0x00003C3C3C3C0000);  # CP437 0xFE
    kashi_fset8(0xFF, 0x0000000000000000);  # CP437 0xFF — blank

    # --- Derive VGA 9x16 from VGA 8x16 + the VGA 9-bit-mode col-9 rule.
    # In VGA text mode the 9th column is generated by the hardware: for
    # codepoints in the CP437 box-drawing range 0xC0..0xDF, col 8 (the
    # leftmost bit of the second byte) repeats col 7 (bit 0 of the first
    # byte) so box-drawing lines connect across cells; for all other
    # codepoints col 8 is 0. We bake this rule at init time so the new
    # 9x16 built-in is just `font16 + computed col-9`, no second table
    # to ship or transcribe. See ADR 0006.
    var dch = KASHI_GLYPH_FIRST;
    while (dch <= KASHI_GLYPH_LAST) {
        var src_base = &kashi_font16 + (dch - KASHI_GLYPH_FIRST) * 16;
        var dst_base = &kashi_font9_16 + (dch - KASHI_GLYPH_FIRST) * 32;
        var dr = 0;
        while (dr < 16) {
            var b0 = load8(src_base + dr);
            var b1 = 0;
            if (dch >= 0xC0) {
                if (dch <= 0xDF) { b1 = (b0 & 1) << 7; }
            }
            store8(dst_base + dr * 2 + 0, b0);
            store8(dst_base + dr * 2 + 1, b1);
            dr = dr + 1;
        }
        dch = dch + 1;
    }

    kashi_font_ready = 1;
    return 0;
}

# 1 once kashi_font_init() has populated the tables, else 0. Lets a
# freestanding consumer assert init ran before the first render (audit
# 2026-05-27, F2 — previously the flag was write-only). Pre-init the
# buffers are zeroed BSS, so access is bounds-safe and renders blank.
fn kashi_font_is_ready() {
    return kashi_font_ready;
}

# --- Metadata accessors (freestanding; pure arithmetic) ---

# Glyph cell width in pixels. Both fonts are 8 px wide. Unknown id -> 0.
fn kashi_font_width(font_id) {
    if (font_id == KASHI_FONT_VGA_8X16) { return 8; }
    if (font_id == KASHI_FONT_CGA_8X8) { return 8; }
    if (font_id == KASHI_FONT_VGA_9X16) { return 9; }
    return 0;
}

# Glyph cell height in pixels (= rows per glyph). Unknown id -> 0.
fn kashi_font_height(font_id) {
    if (font_id == KASHI_FONT_VGA_8X16) { return 16; }
    if (font_id == KASHI_FONT_CGA_8X8) { return 8; }
    if (font_id == KASHI_FONT_VGA_9X16) { return 16; }
    return 0;
}

# First encoded codepoint (0x20 / space) for any valid font. Unknown -> 0.
fn kashi_font_first(font_id) {
    if (font_id == KASHI_FONT_VGA_8X16) { return KASHI_GLYPH_FIRST; }
    if (font_id == KASHI_FONT_CGA_8X8) { return KASHI_GLYPH_FIRST; }
    if (font_id == KASHI_FONT_VGA_9X16) { return KASHI_GLYPH_FIRST; }
    return 0;
}

# Number of encoded glyphs (224) for any valid font. Unknown -> 0.
fn kashi_font_count(font_id) {
    if (font_id == KASHI_FONT_VGA_8X16) { return KASHI_GLYPH_COUNT; }
    if (font_id == KASHI_FONT_CGA_8X8) { return KASHI_GLYPH_COUNT; }
    if (font_id == KASHI_FONT_VGA_9X16) { return KASHI_GLYPH_COUNT; }
    return 0;
}

# Bytes per glyph row = ceil(width / 8). 8-wide built-ins return 1; the
# VGA 9x16 built-in (0.5.1) returns 2. Unknown id -> 0. Added in 0.5.0
# (ADR 0005); extended in 0.5.1 (ADR 0006).
fn kashi_font_stride(font_id) {
    if (font_id == KASHI_FONT_VGA_8X16) { return 1; }
    if (font_id == KASHI_FONT_CGA_8X8) { return 1; }
    if (font_id == KASHI_FONT_VGA_9X16) { return 2; }
    return 0;
}

# 1 if `ch` is in the encoded range [0x20, 0x7F], else 0. Caller-facing
# bounds gate so consumers can decide their own fallback for control chars.
fn kashi_glyph_encoded(ch) {
    if (ch < KASHI_GLYPH_FIRST) { return 0; }
    if (ch > KASHI_GLYPH_LAST) { return 0; }
    return 1;
}

# Base pointer to a glyph's contiguous row bytes within the BSS buffer.
# Returns the address of row 0; the consumer reads `height` bytes from it.
# Returns 0 (null) for an out-of-range char or unknown font — the caller
# must null-check (a freestanding kernel cannot afford a wild deref).
fn kashi_glyph_ptr(font_id, ch) {
    if (kashi_glyph_encoded(ch) == 0) { return 0; }
    if (font_id == KASHI_FONT_VGA_8X16) {
        return &kashi_font16 + (ch - KASHI_GLYPH_FIRST) * 16;
    }
    if (font_id == KASHI_FONT_CGA_8X8) {
        return &kashi_font8 + (ch - KASHI_GLYPH_FIRST) * 8;
    }
    if (font_id == KASHI_FONT_VGA_9X16) {
        return &kashi_font9_16 + (ch - KASHI_GLYPH_FIRST) * 32;
    }
    return 0;
}

# One row byte of a glyph (bit 7 = leftmost pixel). row is 0-based, top
# first. Returns 0 for an out-of-range char, unknown font, or out-of-range
# row — a 0 byte renders as blank, the safe default for a console. For
# wide-glyph fonts (stride > 1) this returns the LEADING byte (byte_idx 0);
# use kashi_glyph_row_byte for the other bytes.
fn kashi_glyph_row(font_id, ch, row) {
    if (kashi_glyph_encoded(ch) == 0) { return 0; }
    var h = kashi_font_height(font_id);
    if (h == 0) { return 0; }
    if (row < 0) { return 0; }
    if (row >= h) { return 0; }
    var base = kashi_glyph_ptr(font_id, ch);
    if (base == 0) { return 0; }
    # Stride-aware (0.5.1). Inline the stride rather than call
    # kashi_font_stride() since this accessor is on the per-row render
    # hot path; the function call adds a few ns. Returns the LEADING
    # byte of the row for wide fonts (matches the ADR 0005 contract);
    # multi-byte access via kashi_glyph_row_byte.
    var stride = 1;
    if (font_id == KASHI_FONT_VGA_9X16) { stride = 2; }
    return load8(base + row * stride);
}

# One row byte at column-byte position `byte_idx` (0 = leftmost 8 px).
# Multi-byte-aware sibling of kashi_glyph_row: for stride-1 fonts (both
# built-ins) only byte_idx == 0 is meaningful — anything else returns 0.
# Bounds-safe: all out-of-range inputs return 0 (blank). Added in 0.5.0
# (ADR 0005); enables wide-glyph access uniformly across the freestanding
# and library-face accessor families.
fn kashi_glyph_row_byte(font_id, ch, row, byte_idx) {
    if (byte_idx < 0) { return 0; }
    var stride = kashi_font_stride(font_id);
    if (stride == 0) { return 0; }
    if (byte_idx >= stride) { return 0; }
    if (kashi_glyph_encoded(ch) == 0) { return 0; }
    var h = kashi_font_height(font_id);
    if (h == 0) { return 0; }
    if (row < 0) { return 0; }
    if (row >= h) { return 0; }
    var base = kashi_glyph_ptr(font_id, ch);
    if (base == 0) { return 0; }
    return load8(base + row * stride + byte_idx);
}
